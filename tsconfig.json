{
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "Bundler",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "lib": ["DOM", "ES2023"],
    "types": ["node"],
    "strict": false,
    "allowImportingTsExtensions": true
  }
}
