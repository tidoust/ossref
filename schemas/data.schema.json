{
  "$schema": "http://json-schema.org/draft-07/schema",
  "description": "Indexed list of open-source projects",
  "type": "object",
  "properties": {
    "projects": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/definitions/ProjectData"
      }
    }
  },
  "required": ["projects"],
  "additionalProperties": false,
  "definitions": {
    "ProjectData": {
      "description": "An open-source project data entry",
      "type": "object",
      "properties": {
        "id": {
          "description": "Project ID",
          "$ref": "#/definitions/NonEmptyString"
        },
        "name": {
          "description": "Project name",
          "$ref": "#/definitions/NonEmptyString"
        },
        "description": {
          "description": "Short description of the project, as a plain text string",
          "$ref": "#/definitions/NonEmptyString"
        },
        "description_html": {
          "description": "Short description of the project, as an HTML string",
          "$ref": "#/definitions/NonEmptyString"
        },
        "logo": {
          "description": "URL of the project's logo, when one exists",
          "$ref": "#/definitions/Url"
        },
        "owner": {
          "description": "Name of the organization that hosts the project when there is one (e.g., \"W3C\"), the username of the owner for projects that are hosted on GitHub or other source forges (e.g., \"tobie\"), or the name of the copyright owner",
          "$ref": "#/definitions/NonEmptyString"
        },
        "homepage": {
          "description": "URL of the project's home page",
          "$ref": "#/definitions/Url"
        },
        "repository": {
          "description": "URL of the repository that contains the source code",
          "$ref": "#/definitions/Url"
        },
        "licenses": {
          "description": "Open-source licenses for the project, using an SPDX license ID. Use \"other\" if the project uses a custom license.",
          "$ref": "#/definitions/Strings"
        },
        "purposes": {
          "description": "Main purposes that the project addresses",
          "type": "array",
          "items": { "$ref": "#/definitions/Purpose" },
          "minItems": 1
        },
        "categories": {
          "description": "Main categories for the project within W3C",
          "type": "array",
          "items": { "$ref": "#/definitions/Category" },
          "minItems": 1
        },
        "status": { "$ref": "#/definitions/Status" }
      },
      "required": [
        "name",
        "description",
        "owner",
        "homepage",
        "repository",
        "licenses",
        "purposes",
        "categories",
        "status"
      ],
      "additionalProperties": false
    },
    "Category": {
      "description": "Project category within W3C",
      "type": "string",
      "enum": ["adoption", "implementation", "incubation", "tool"]
    },
    "NonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "Purpose": {
      "description": "Project purpose",
      "type": "string",
      "enum": [
        "authoring",
        "dashboard",
        "data",
        "library",
        "group tool",
        "backend",
        "frontend",
        "samples",
        "tests",
        "validation"
      ]
    },
    "Status": {
      "type": "string",
      "enum": ["active", "maintained", "dormant"]
    },
    "Strings": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/NonEmptyString"
      },
      "minItems": 1
    },
    "Url": {
      "type": "string",
      "format": "url",
      "pattern": "^https?:\/\/.+"
    }
  }
}
