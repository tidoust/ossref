{
  "name": "oss-w3c",
  "description": "List of open-source software developed by W3C or used for progressing specifications at W3C",
  "version": "0.1.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/tidoust/oss-w3c.git"
  },
  "type": "module",
  "main": "index.ts",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "schematypes": "sh -c \"npx quicktype --lang='typescript' --src-lang schema --src ./schemas/data.schema.json --just-types --prefer-unions --prefer-const-values --top-level=ProjectsIndex | prettier --stdin-filepath ./scripts/types.quicktype.ts\"",
    "schematypes:write": "npm run --silent schematypes > ./scripts/types.quicktype.ts",
    "build": "tsx scripts/build.ts && prettier --write index.json",
    "generate-auto-files": "tsx scripts/generate-auto-files.ts",
    "format": "prettier --write .",
    "test:format": "prettier --check .",
    "test:yaml": "tsx --test test/validate-yaml.ts",
    "test:projects": "tsx --test test/validate-projects.ts",
    "test:list": "tsx --test test/validate-list.ts",
    "test:types": "tsc",
    "test": "tsx --test && npm run test:types && npm run test:format"
  },
  "devDependencies": {
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "commander": "^14.0.3",
    "hast-util-to-string": "^3.0.1",
    "prettier": "^3.8.3",
    "quicktype": "^23.2.6",
    "rehype-parse": "^9.0.1",
    "rehype-stringify": "^10.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "tsx": "^4.21.0",
    "unified": "^11.0.5",
    "yaml": "^2.8.4"
  },
  "allowScripts": {
    "esbuild@0.27.7": true
  }
}
